<!DOCTYPE html>
<html lang="en">
<head>
  
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="MAGIZHVAGAM - Premium Return Gifts & Customized Gifts for Weddings, Birthdays, Baby Showers, Corporate events, and Festivals. Handcrafted luxury Return Gifts.">
  <title>MAGIZHVAGAM | Premium Return Gifts & Customized Gift Store</title>
  
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/animations.css">
  <link rel="stylesheet" href="/assets/css/responsive.css">
  
  <style>
    /* Slider layout */
    .hero-slider {
      position: relative;
      height: 600px;
      overflow: hidden;
      margin-bottom: 60px;
    }
    
    /* Why Choose Us style */
    .feature-card {
      padding: 30px;
      border-radius: 16px;
      text-align: center;
    }
    .feature-icon {
      font-size: 36px;
      margin-bottom: 16px;
      color: hsl(var(--primary-purple));
      display: flex;
      justify-content: center;
    }
    .feature-icon svg {
      width: 36px;
      height: 36px;
      stroke-width: 1.8;
    }
  </style>
</head>
<body class="home-page">

  <!-- Shared Header -->
  <header id="main-header"></header>

  <!-- Hero Section -->
  <section class="hero-slider" id="hero-slider-container">
    <!-- Dynamic banners will load here -->
    <div style="display:flex; justify-content:center; align-items:center; height:100%;">
      <div class="spinner"></div>
    </div>
  </section>

  <!-- Highlights Categories -->
  <section id="categories" class="container" style="margin-bottom: 80px;">
    <h2 style="font-size:32px; font-family:'Outfit'; text-align:center; margin-bottom:12px; color:var(--text-color);">Shop By Category</h2>
    <p style="text-align:center; color:var(--text-muted); margin-bottom:40px; font-size:16px;">Handpicked gift hampers tailored for your celebratory milestones</p>
    <div class="grid grid-4" id="category-highlights-container">
      <!-- Loaded dynamically -->
    </div>
  </section>

  <!-- Featured Products -->
  <section class="container" style="margin-bottom: 80px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:40px;">
      <div>
        <h2 style="font-size:30px; font-family:'Outfit'; color:var(--text-color);">Featured Collections</h2>
        <p style="color:var(--text-muted); font-size:15px; margin-top:4px;">Trending returns gifts of the season</p>
      </div>
      <a href="/products.html" class="btn btn-secondary" style="padding:8px 20px; font-size:14px; border-radius:8px;">View All</a>
    </div>
    <div class="grid grid-4" id="featured-products-grid">
      <!-- Loaded dynamically -->
    </div>
  </section>

  <!-- Promotional Banners -->
  <section class="container grid grid-2" id="promotional-banners-container" style="margin-bottom: 80px;">
    <!-- Loaded dynamically -->
  </section>

  <!-- Best Sellers -->
  <section class="container" style="margin-bottom: 80px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:40px;">
      <div>
        <h2 style="font-size:30px; font-family:'Outfit'; color:var(--text-color);">Best Sellers</h2>
        <p style="color:var(--text-muted); font-size:15px; margin-top:4px;">Loved and ordered by thousands of event planners</p>
      </div>
      <a href="/products.html?sort=bestSelling" class="btn btn-secondary" style="padding:8px 20px; font-size:14px; border-radius:8px;">View All</a>
    </div>
    <div class="grid grid-4" id="bestseller-products-grid">
      <!-- Loaded dynamically -->
    </div>
  </section>

  <!-- Trust Badges: Why Choose Us -->
  <section style="background: rgba(106, 13, 173, 0.03); padding: 80px 0; margin-bottom: 80px;">
    <div class="container">
      <h2 style="font-size:32px; font-family:'Outfit'; text-align:center; margin-bottom:12px; color:var(--text-color);">Why Choose Magizhvagam?</h2>
      <p style="text-align:center; color:var(--text-muted); margin-bottom:50px;">We craft premium, high-quality experiences that make events unforgettable</p>
      
      <div class="grid grid-4">
        <div class="feature-card glass hover-lift">
          <div class="feature-icon"><i data-lucide="sparkles"></i></div>
          <h4 style="font-size:18px; margin-bottom:12px; font-family:'Outfit';">Artisanal Quality</h4>
          <p style="color:var(--text-muted); font-size:14px; line-height:1.6;">Every gift is hand-carved, inspected, and wrapped to meet luxury guidelines.</p>
        </div>
        
        <div class="feature-card glass hover-lift">
          <div class="feature-icon"><i data-lucide="gift"></i></div>
          <h4 style="font-size:18px; margin-bottom:12px; font-family:'Outfit';">Tailored Customization</h4>
          <p style="color:var(--text-muted); font-size:14px; line-height:1.6;">Add personalized messages, card layouts, engraving, and event signatures.</p>
        </div>

        <div class="feature-card glass hover-lift">
          <div class="feature-icon"><i data-lucide="truck"></i></div>
          <h4 style="font-size:18px; margin-bottom:12px; font-family:'Outfit';">Express Bulk Delivery</h4>
          <p style="color:var(--text-muted); font-size:14px; line-height:1.6;">Direct priority shipping to event venues, fully secured package tracking.</p>
        </div>

        <div class="feature-card glass hover-lift">
          <div class="feature-icon"><i data-lucide="handshake"></i></div>
          <h4 style="font-size:18px; margin-bottom:12px; font-family:'Outfit';">Trustworthy Support</h4>
          <p style="color:var(--text-muted); font-size:14px; line-height:1.6;">Dedicated WhatsApp hotlines and 1-on-1 assistance for bulk organizers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- New Arrivals -->
  <section class="container" style="margin-bottom: 80px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:40px;">
      <div>
        <h2 style="font-size:30px; font-family:'Outfit'; color:var(--text-color);">New Arrivals</h2>
        <p style="color:var(--text-muted); font-size:15px; margin-top:4px;">Fresh additions to celebrate your special moments</p>
      </div>
      <a href="/products.html?sort=newest" class="btn btn-secondary" style="padding:8px 20px; font-size:14px; border-radius:8px;">View All</a>
    </div>
    <div class="grid grid-4" id="newarrival-products-grid">
      <!-- Loaded dynamically -->
    </div>
  </section>

  <!-- Testimonials -->
  <section class="container" style="margin-bottom: 80px;">
    <h2 style="font-size:32px; font-family:'Outfit'; text-align:center; margin-bottom:12px; color:var(--text-color);">What Our Clients Say</h2>
    <p style="text-align:center; color:var(--text-muted); margin-bottom:45px;">Real reviews from verified hosts & bulk buyers</p>
    <div class="grid grid-3" id="testimonials-container">
      <!-- Loaded dynamically -->
    </div>
  </section>

  <!-- Newsletter -->
  <section class="container" style="margin-bottom: 40px;">
    <div class="glass" style="padding: 50px; border-radius: 20px; text-align: center; background: linear-gradient(135deg, rgba(106, 13, 173, 0.08) 0%, rgba(255, 79, 129, 0.08) 100%);">
      <h3 style="font-size: 26px; margin-bottom: 12px; font-family: 'Outfit';">Get Exclusive Offers</h3>
      <p style="color: var(--text-muted); font-size: 15px; max-width: 500px; margin: 0 auto 30px;">Subscribe to receive promotion updates, new collection drops, and bulk discount campaign alerts.</p>
      
      <form style="display: flex; justify-content: center; gap: 10px; max-width: 480px; margin: 0 auto;" onsubmit="event.preventDefault(); showToast('Subscribed to newsletter!', 'success'); this.reset();">
        <input type="email" placeholder="Your Email Address" style="padding: 12px 20px; border-radius: 25px; border: 1px solid var(--card-border); flex-grow: 1;" required>
        <button type="submit" class="btn btn-primary" style="border-radius: 25px;">Subscribe</button>
      </form>
    </div>
  </section>

  <!-- Shared Footer -->
  <footer id="main-footer"></footer>

  <!-- Scripts -->
  <script src="/assets/js/app.js"></script>
  <script src="/assets/js/home.js"></script>
</body>
</html>
